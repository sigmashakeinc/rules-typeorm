# typeorm_write_safety.rules
# Technology: typeorm | Capability: write

rule typeorm-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "query("
  MESSAGE "Blocked an unsafe pattern in typeorm. Use the recommended best practices for 2025/2026."
}

rule typeorm-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "createConnection"
  MESSAGE "You are using an outdated API for typeorm. Please upgrade to the newer API."
}
